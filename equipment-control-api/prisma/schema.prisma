// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Equipment {
  id                                String                                    @id @default(uuid())
  numeroOrdem                       Int                                       @unique @default(autoincrement())
  numeroSerieBase                   String?
  numeroSerie                       String?   
  tag                               String?                                   @unique
  dataSolicitacao                   DateTime? 
  dataInicio                        DateTime?
  dataTermino                       DateTime?
  statusProducao                    StatusProducao                            @default(PROGRAMADA)  
  tipoEquipamentoId                 String?
  tipoEquipamento                   TipoEquipamento? @relation(fields: [tipoEquipamentoId], references: [id])
  modelo                            String? 
  descricao                         String?

  listaPecas                        Boolean                                   @default(false)
  sequenciaMontagem                 Boolean                                   @default(false)
  inspecaoMontagem                  Boolean                                   @default(false)
  historicoEquipamento              Boolean                                   @default(false)
  procedimentoTesteInspecaoMontagem Boolean                                   @default(false)

  criadoEm                          DateTime                                  @default(now())
  atualizadoEm                      DateTime                                  @updatedAt

  itensSeriados                     ItemSeriado[]
  observacoes                       ObservacaoProducao[]
}

model ItemSeriado {
  id                String          @id             @default(uuid())
  producaoID        String
  descricao         String
  criadoEm          DateTime        @default(now())

  equipment         Equipment       @relation(fields: [producaoID], references: [id], onDelete: Cascade)
}

enum StatusProducao {
  PROGRAMADA
  EM_ANDAMENTO
  CONCLUIDA
}

model ObservacaoProducao {
  id          String        @id @default(uuid())
  producaoId  String
  descricao   String
  criadoEm    DateTime      @default(now())

  equipment   Equipment     @relation(fields: [producaoId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                            @id @default(uuid())
  nome                    String        
  email                   String                            @unique
  senha                   String        
  ativo                   Boolean                           @default(true)
  precisaTrocarSenha      Boolean                           @default(true)
  criadoEm                DateTime                          @default(now())   
}

model TipoEquipamento {
  id                String          @id @default(uuid())
  nome              String          @unique
  ativo             Boolean         @default(true)
  criadoEm          DateTime        @default(now())
  atualizadoEm      DateTime        @updatedAt

  equipments Equipment[]
}
